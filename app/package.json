{
  "name": "anibridge-mappings",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview --host",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "diff": "^8.0.4",
    "fflate": "^0.8.2",
    "hono": "^4.12.12",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "vite": "^8.0.8",
    "wrangler": "^4.81.1"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
